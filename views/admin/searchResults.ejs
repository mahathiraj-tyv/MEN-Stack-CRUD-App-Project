<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Admin - Search Results | TravelZap</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

<%- include('../partials/header') %>

<main class="container mt-5">

  <h2 class="text-center mb-4">
    Tickets from <%= source %> → <%= destination %>
  </h2>

  <p class="text-center text-muted">
    Travel Date: <%= date %>
  </p>

  <% if (tickets.length === 0) { %>
    <div class="alert alert-danger text-center">
      No tickets found.
    </div>
  <% } else { %>

    <div class="row g-4 mt-3">

      <% tickets.forEach(ticket => { %>

        <div class="col-md-4">
          <div class="card shadow-sm h-100 border <%= ticket.availableSeats > 0 ? 'border-success' : 'border-danger' %>">
            <div class="card-body text-center">

              <h5 class="card-title"><%= ticket.busName %></h5>

              <p class="mb-1">
                <strong>Route:</strong> <%= ticket.source %> → <%= ticket.destination %>
              </p>
              <p class="mb-1">
                <strong>Departure:</strong> <%= ticket.departureTime %> | 
                <strong>Arrival:</strong> <%= ticket.arrivalTime %>
              </p>
              <p class="mb-1">
                <strong>Seats:</strong>
                <span class="<%= ticket.availableSeats > 0 ? 'text-success' : 'text-danger' %>">
                  <%= ticket.availableSeats %>
                </span>
              </p>
              <p class="mb-2"><strong>Price:</strong> ₹<%= ticket.price %></p>

              <div class="d-flex gap-2 justify-content-center">
                <a href="/admin/editTicket/<%= ticket._id %>" class="btn btn-warning btn-sm">
                  Edit
                </a>
                <form action="/admin/deleteTicket/<%= ticket._id %>" method="POST" onsubmit="return confirm('Are you sure you want to delete this ticket?');">
                  <button type="submit" class="btn btn-danger btn-sm">
                    Delete
                  </button>
                </form>
              </div>

            </div>
          </div>
        </div>

      <% }) %>

    </div>

  <% } %>

</main>

<%- include('../partials/footer') %>

</body>
</html>