<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Tickets - TravelZap</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../partials/header') %>
<main class="container py-5">

  <h2 class="mb-4 text-center fw-bold">
    🚌 Bus Route Management
  </h2>

  <div class="row">

    <% tickets.forEach(ticket => { %>

      <div class="col-md-6 col-lg-4 mb-4">
        <div class="card shadow-sm border-0 h-100">

          <div class="card-body">

            <h5 class="fw-bold mb-2">
              <%= ticket.source %> → <%= ticket.destination %>
            </h5>

            <p class="mb-1">
              <strong>Seats Available:</strong> <%= ticket.availableSeats %>
            </p>

            <p class="mb-2">
              <strong>Status:</strong>
              <% if (ticket.isApproved) { %>
                <span class="badge bg-success">Approved</span>
              <% } else { %>
                <span class="badge bg-warning text-dark">Pending</span>
              <% } %>
            </p>

            <div class="mt-3">

              <a href="/admin/edit/<%= ticket._id %>" class="btn btn-outline-primary btn-sm me-2">
                Edit Route
              </a>

              <% if (!ticket.isApproved) { %>
                <form action="/admin/approve/<%= ticket._id %>" method="POST" class="d-inline">
                  <button type="submit" class="btn btn-success btn-sm">
                    Approve Route
                  </button>
                </form>
              <% } %>

            </div>

          </div>
        </div>
      </div>

    <% }) %>

  </div>
</main>
<%- include('../partials/footer') %>
</body>
</html>