<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Admin Dashboard - TravelZap</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

<%- include('../partials/header') %>

  <!-- ===================== ADD TICKET ===================== -->
  <div class="card mb-5 shadow-sm border-0">
    <div class="card-body">
      <h4 class="mb-4">Add New Ticket</h4>

      <form method="POST" action="/admin/tickets" class="row g-3">

        <div class="col-md-3">
          <label class="form-label">Source</label>
          <input type="text" name="source" class="form-control" required>
        </div>

        <div class="col-md-3">
          <label class="form-label">Destination</label>
          <input type="text" name="destination" class="form-control" required>
        </div>

        <div class="col-md-2">
          <label class="form-label">Available Seats</label>
          <input type="number" name="availableSeats" class="form-control" min="0" required>
        </div>

        <div class="col-md-2">
          <label class="form-label">Price (₹)</label>
          <input type="number" name="price" class="form-control" min="0" required>
        </div>

        <div class="col-md-2 d-flex align-items-end">
          <button type="submit" class="btn btn-success w-100">
            Add Ticket
          </button>
        </div>

      </form>
    </div>
  </div>


  <!-- ===================== PENDING CUSTOMERS ===================== -->
  <div class="card mb-5 shadow-sm border-0">
    <div class="card-body">
      <h4 class="mb-4">Pending Customers</h4>

      <% const pendingCustomers = (customers || []).filter(c => !c.approved); %>

      <% if (pendingCustomers.length === 0) { %>
        <p class="text-muted">No pending approvals.</p>
      <% } else { %>

        <ul class="list-group">
          <% pendingCustomers.forEach(c => { %>
            <li class="list-group-item d-flex justify-content-between align-items-center">

              <div>
                <strong><%= c.name %></strong><br>
                <small class="text-muted"><%= c.email %></small>
              </div>

              <form method="POST" action="/admin/approve-customer/<%= c._id %>">
                <button type="submit" class="btn btn-primary btn-sm">
                  Approve
                </button>
              </form>

            </li>
          <% }) %>
        </ul>

      <% } %>

    </div>
  </div>


  <!-- ===================== ALL TICKETS ===================== -->
  <div class="card shadow-sm border-0">
    <div class="card-body">
      <h4 class="mb-4">All Tickets</h4>

      <% if (!tickets || tickets.length === 0) { %>
        <p class="text-muted">No tickets available.</p>
      <% } else { %>

        <div class="row g-4">

          <% tickets.forEach(ticket => { %>
            <div class="col-md-4">
              <div class="card h-100 shadow-sm">

                <div class="card-body text-center">

                  <h5 class="card-title fw-bold">
                    <%= ticket.source %> → <%= ticket.destination %>
                  </h5>

                  <p class="mb-1">
                    Seats:
                    <span class="<%= ticket.availableSeats > 0 ? 'text-success' : 'text-danger' %> fw-semibold">
                      <%= ticket.availableSeats %>
                    </span>
                  </p>

                  <p class="mb-3">
                    Price:
                    <span class="fw-semibold">$<%= ticket.price %></span>
                  </p>

                  <!-- Edit Button -->
                  <a href="/admin/tickets/<%= ticket._id %>/edit"
                     class="btn btn-outline-primary btn-sm me-2">
                    Edit
                  </a>

                  <!-- Delete Button -->
                  <form action="/admin/tickets/<%= ticket._id %>/delete"
                        method="POST"
                        class="d-inline">
                    <button type="submit"
                            class="btn btn-outline-danger btn-sm"
                            onclick="return confirm('Are you sure you want to delete this ticket?')">
                      Delete
                    </button>
                  </form>

                </div>

              </div>
            </div>
          <% }) %>

        </div>

      <% } %>

    </div>
  </div>

</main>

<%- include('../partials/footer') %>

</body>
</html>