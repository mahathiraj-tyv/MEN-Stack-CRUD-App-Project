<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>TravelZap - Bus Booking</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.0/font/bootstrap-icons.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<%- include('partials/header') %>

<section class="bg-light py-5 text-center">
  <div class="container">

    <h1 class="display-4 fw-bold mb-3">
      🚌 TravelZap
    </h1>

    <p class="lead mb-4">
      Book affordable bus tickets across cities quickly and securely.
    </p>
<form action="/customer/search-tickets" method="GET" class="row g-2 justify-content-center mt-4">

  <div class="col-md-3">
    <input type="text" name="source" class="form-control" placeholder="From City" required>
  </div>

  <div class="col-md-3">
    <input type="text" name="destination" class="form-control" placeholder="To City" required>
  </div>

  <div class="col-md-2">
    <input 
    type="date" 
    name="date" 
    class="form-control"
    min="<%= new Date().toISOString().split('T')[0] %>"
    required>
  </div>

  <div class="col-md-2">
    <button type="submit" class="btn btn-info w-100">
      Search Buses
    </button>
  </div>

</form>

  </div>
</section>

<section class="py-5">
  <div class="container">
    <div class="row text-center">

      <div class="col-md-4">
        <h5 class="fw-bold">Wide Network</h5>
        <p>Travel between major cities with ease.</p>
      </div>

      <div class="col-md-4">
        <h5 class="fw-bold">Affordable Prices</h5>
        <p>Best fares with no hidden charges.</p>
      </div>

      <div class="col-md-4">
        <h5 class="fw-bold">Easy Booking</h5>
        <p>Simple and fast ticket booking process.</p>
      </div>

    </div>
  </div>
</section>
 <%- include('partials/footer') %>
</body>
</html>