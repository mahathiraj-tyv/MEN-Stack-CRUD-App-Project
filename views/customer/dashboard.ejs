<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Admin Dashboard - TravelZap</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

<%- include('../partials/header') %>

  <!-- ================= AVAILABLE TICKETS ================= -->
  <h2 class="text-center mb-5 fw-bold">Available Tickets</h2>

  <% if (tickets.length === 0) { %>
    <p class="text-center text-muted">No tickets available.</p>
  <% } else { %>
    <div class="row g-4">
      <% tickets.forEach(ticket => { %>
        <div class="col-md-4">
          <div class="card h-100 shadow-sm">

            <div class="card-body text-center d-flex flex-column justify-content-between">

              <div>
                <h5 class="fw-bold">
                  <%= ticket.source %> → <%= ticket.destination %>
                </h5>

                <p class="mb-1">
                  Seats:
                  <span class="<%= ticket.availableSeats > 0 ? 'text-success' : 'text-danger' %> fw-semibold">
                    <%= ticket.availableSeats %>
                  </span>
                </p>

                <p class="mb-3">
                  Price:
                  <span class="fw-semibold">₹<%= ticket.price %></span>
                </p>
              </div>

              <div>
                <% if(ticket.availableSeats > 0){ %>
                  <form method="POST" action="/customer/book/<%= ticket._id %>">
                  <div class="mb-2">
                  <input 
                     type="number"
                     name="seats"
                     class="form-control"
                     min="1"
                     max="<%= ticket.availableSeats %>"
                    required>
                    </div>

  <button class="btn btn-warning w-100">
    Book Now
  </button>
</form>
                <% } else { %>
                  <button class="btn btn-secondary w-100" disabled>
                    Sold Out
                  </button>
                <% } %>
              </div>

            </div>

          </div>
        </div>
      <% }) %>
    </div>
  <% } %>


  <!-- ================= MY BOOKINGS ================= -->
  <h3 class="mt-5 mb-4 fw-bold">My Bookings</h3>

<% if (myBookings.length === 0) { %>
  <p class="text-muted">You have not booked any tickets yet.</p>
<% } else { %>
  <div class="row g-4">

    <% myBookings.forEach(ticket => { %>

      <div class="col-md-4">
        <div class="card border-primary shadow-sm h-100">
          <div class="card-body text-center">

            <h5 class="fw-bold text-primary">
              <%= ticket.source %> → <%= ticket.destination %>
            </h5>

            <p class="mb-1">Seats Booked: <strong><%= ticket.seatsBooked %></strong></p>

            <p class="mb-2">Total Price: ₹<%= ticket.price * ticket.seatsBooked %></p>
    
            <form method="POST" action="/customer/cancel/<%= ticket._id %>">
              <button class="btn btn-outline-danger btn-sm w-100">
                Cancel Booking
              </button>
            </form>

          </div>
        </div>
      </div>

    <% }) %>

  </div>
<% } %>
</form>
</main>

<%- include('../partials/footer') %>

</body>
</html>